{
  "name": "opencheckout",
  "version": "0.2.0",
  "license": "AGPL-3.0-only",
  "private": true,
  "scripts": {
    "dev": "node scripts/ensure-schema.mjs && next dev",
    "build": "next build",
    "start": "node scripts/ensure-schema.mjs && next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run lint && npm run test && npm run build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit push",
    "maintenance:run": "node scripts/maintenance.mjs",
    "setup": "node scripts/setup.mjs"
  },
  "dependencies": {
    "@interledger/open-payments": "^7.4.0",
    "better-sqlite3": "^12.10.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.18.0",
    "nanoid": "^5.1.11",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
