# Database path (default: data/opencheckout.db)
DATABASE_URL=data/opencheckout.db

# Encryption key for merchant private keys at rest (64 hex chars = 32 bytes)
ENCRYPTION_KEY=

# Server configuration
BASE_URL=http://localhost:3080

# Optional comma-separated browser origins allowed to call /api/checkout.
# Leave empty for the recommended server-to-server-only API.
CORS_ALLOWED_ORIGINS=

# Optional: enables the authenticated expiry/idempotency/webhook maintenance job.
MAINTENANCE_SECRET=
